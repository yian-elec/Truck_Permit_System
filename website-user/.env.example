# 可選。未設則在瀏覽器內用 http://<開啟本頁的 host>:<VITE_API_PORT 或 8000>，外網用 IP 開頁可連同機後端。
# 前後分離/HTTPS/不同網域時請設完整 API 根位址。
# VITE_API_BASE_URL=https://api.example.com
# VITE_API_PORT=8000
VITE_APP_NAME=Heavy Truck Permit
VITE_GOOGLE_MAPS_API_KEY=
# Production: must match real object storage bucket. Local dev: optional — defaults to permit-dev and skips PUT when the API returns the noop presign URL (storage.example.invalid).
# VITE_ATTACHMENT_BUCKET_NAME=my-real-bucket
VITE_ATTACHMENT_STORAGE_PROVIDER=s3
