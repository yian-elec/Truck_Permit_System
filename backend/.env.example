# Truck_Permit_System Backend - 環境變數設定檔
# 此文件包含所有應用程式所需的環境變數

# 環境設定
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# 資料庫設定 (PostgreSQL)
# 連線驗證（專案根目錄、已啟用 venv）: .venv/bin/python scripts/check_postgres_connection.py
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=truck_permit
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false
DB_ECHO_POOL=false

# JWT 設定
JWT_SECRET=your-secret-key-here-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=3600
JWT_REFRESH_EXPIRE_SECONDS=86400

# 密碼設定
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# 加密設定
BCRYPT_ROUNDS=12

# CORS 設定 (JSON 格式)
CORS_ORIGINS=["*"]
CORS_METHODS=["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
CORS_HEADERS=["*"]

# 速率限制設定
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# 其他安全設定
SESSION_TIMEOUT=1800
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# API 設定
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
API_PREFIX=/api
API_TITLE=Truck_Permit_System API
API_DESCRIPTION=Truck_Permit_System Backend API
API_VERSION_INFO=1.0.0
API_DOCS_URL=/docs
API_REDOC_URL=/redoc
API_OPENAPI_URL=/openapi.json
API_HEALTH_CHECK_URL=/health
API_MAX_REQUEST_SIZE=10485760
API_REQUEST_TIMEOUT=30
API_RESPONSE_TIMEOUT=30
API_DEFAULT_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100
API_CACHE_TTL=300
API_ENABLE_METRICS=true
API_ENABLE_TRACING=false

# development 時 init_db 結束後建立後台 Dev 帳（system + admin 角色、無 MFA；預設啟用）
# DEV_IAM_ADMIN_SEED=1
# DEV_IAM_ADMIN_USERNAME=dev_admin
# DEV_IAM_ADMIN_EMAIL=dev_admin@truckpermitsystem.local
# DEV_IAM_ADMIN_PASSWORD=AdminDev123!

# UC-ROUTE-01：地理編碼（stub=雜湊假座標，僅供開發；production 建議 nominatim）
GEOCODING_MODE=stub
# GEOCODING_MODE=nominatim
# Nominatim 須自訂 User-Agent（含聯絡方式），見 https://operations.osmfoundation.org/policies/nominatim/
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_TIMEOUT_S=10
# NOMINATIM_USER_AGENT=YourApp/1.0 (contact: you@example.com)

# UC-ROUTE-02：候選路線模式（original=開發用 Stub；mvp=Overpass/OSM 道路鏈）
ROUTING_MODE=mvp
# ROUTING_MODE=original
# 可選：自架 Overpass 或調整逾時（秒）
# OVERPASS_URL=https://overpass-api.de/api/interpreter
# OVERPASS_TIMEOUT_S=60

# 測試設定
TEST_DB_NAME=truck_permit_test
TEST_JWT_SECRET=test-secret-key-for-testing
TEST_API_HOST=localhost
TEST_API_PORT=8000
TEST_USERNAME_PREFIX=testuser
TEST_PASSWORD=password123
TEST_EMAIL_DOMAIN=truckpermitsystem.local
